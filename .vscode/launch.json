{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "API + agent (uvicorn, debug)",
      "type": "debugpy",
      "request": "launch",
      "preLaunchTask": "docker: Redis up",
      "module": "uvicorn",
      "args": ["app.main:app", "--host", "127.0.0.1", "--port", "8000"],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "API + agent (uvicorn, debug + reload)",
      "type": "debugpy",
      "request": "launch",
      "preLaunchTask": "docker: Redis up",
      "module": "uvicorn",
      "args": ["app.main:app", "--host", "127.0.0.1", "--port", "8000", "--reload"],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "subProcess": true,
      "justMyCode": false
    }
  ]
}
