
# LLM Provider
# — docker compose injects LLM_PROVIDER + OLLAMA_BASE_URL into the api container from THIS file
#   (see docker-compose.yml environment block).
# — For Dockerized Ollama (see docs/project-instruction/docker.md): use profile ollama and set URLs below.
LLM_PROVIDER=openai
# Host/native Ollama: http://localhost:11434/v1  |  API container → Ollama service: http://ollama:11434/v1
OLLAMA_BASE_URL=http://localhost:11434/v1

# Optional: default model for ollama-pull when using `docker compose --profile ollama` (match config/ollama.yaml)
# OLLAMA_PULL_MODEL=qwen2.5:7b-instruct-q4_K_M

# Optional: enable the `ollama` compose profile without passing --profile every time
# COMPOSE_PROFILES=ollama

OPENAI_API_KEY=your_openai_api_key_here

# Tool API keys
WEATHER_API_KEY=your_openweather_or_provider_key_here
TAVILY_API_KEY=your_tavily_key_here
EXCHANGE_API_KEY=your_exchangerate_key_here

# API layer (app/) — docker-compose overrides DATABASE_URL / REDIS_URL for containers
DATABASE_URL=sqlite+aiosqlite:///./data/app.db
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_OPTIONAL=true
CACHE_TTL_SECONDS=3600
CORS_ORIGINS=http://localhost:5173
# API_KEY=
# Optional — if API_KEY is set, set the same value here so `docker compose` can bake it into the chat UI build
# VITE_API_KEY=
